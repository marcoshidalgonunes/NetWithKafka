{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "BankAccounts": "Host=localhost;Port=5432;Database=bank_accounts;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ProducerTopic": "transaction-processed",
    "ConsumerTopic": "transaction-received",
    "ConsumerGroupId": "received-group",
    "DeadLetterTopic": "transaction-received-dlt",
    "ProduceTimeoutMs": 5000
  },
  "Worker": {
    "BatchIntervalMs": 1000,
    "BatchFlushThreshold": 10,
    "BatchFlushMinAgeMs": 500
  }
}
