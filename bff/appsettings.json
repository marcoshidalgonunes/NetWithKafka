{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ProducerTopic": "transaction-received",
    "ConsumerTopic": "transaction-processed",
    "ConsumerGroupId": "processed-group",
    "DeadLetterTopic": "transaction-processed-dlt",
    "TimeoutMs": 10000,
    "RetryMaxAttempts": 3,
    "RetryBackoffMs": 2000
  },
  "AllowedHosts": "*"
}
